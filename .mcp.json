{
  "mcpServers": {
    "radikabunavi": {
      "type": "http",
      "url": "https://radikabunavi.com/mcp",
      "headers": {
        "Authorization": "Bearer ${RADIKABUNAVI_API_KEY}"
      }
    },
    "tdnet": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "tdnet-disclosure-mcp",
        "serve"
      ]
    }
  }
}
